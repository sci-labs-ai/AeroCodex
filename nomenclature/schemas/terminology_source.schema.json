{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerocodex.internal/schemas/terminology_source.schema.json",
  "title": "AeroCodex Terminology Source Registry",
  "type": "object",
  "required": [
    "version",
    "kind",
    "records"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "kind": {
      "const": "acx.terminology_sources"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "authority",
          "source_type",
          "title",
          "domains",
          "authority_rank",
          "ingestion_mode",
          "status"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^acx:source:"
          },
          "authority": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": [
              "string",
              "null"
            ]
          },
          "domains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "authority_rank": {
            "type": "string"
          },
          "ingestion_mode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "license_notes": {
            "type": "string"
          },
          "retrieval_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_verified": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

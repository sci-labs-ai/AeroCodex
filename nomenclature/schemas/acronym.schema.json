{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerocodex.internal/schemas/acronym.schema.json",
  "title": "AeroCodex Acronym Registry",
  "type": "object",
  "required": [
    "version",
    "kind",
    "records"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "kind": {
      "const": "acx.acronyms"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "acronym_id",
          "token",
          "expansion",
          "namespace",
          "domains",
          "status",
          "source",
          "first_use"
        ],
        "properties": {
          "acronym_id": {
            "type": "string",
            "pattern": "^acx:acr:"
          },
          "token": {
            "type": "string",
            "minLength": 2
          },
          "preferred_token": {
            "type": "string"
          },
          "expansion": {
            "type": "string",
            "minLength": 2
          },
          "namespace": {
            "const": "acronym"
          },
          "canonical": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "canonical_namespace": {
            "type": "string"
          },
          "domains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "approved",
              "ambiguous",
              "deprecated",
              "superseded",
              "rejected",
              "external"
            ]
          },
          "collision_group": {
            "type": "string"
          },
          "source": {
            "type": "object",
            "required": [
              "authority",
              "source_id",
              "authority_rank",
              "evidence"
            ],
            "properties": {
              "authority": {
                "type": "string"
              },
              "source_id": {
                "type": "string"
              },
              "authority_rank": {
                "type": "string"
              },
              "evidence": {
                "type": "string"
              },
              "source_locator": {
                "type": "string"
              },
              "retrieved_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": true
          },
          "first_use": {
            "type": "object",
            "required": [
              "requires_definition"
            ],
            "properties": {
              "requires_definition": {
                "type": "boolean"
              },
              "allowed_after_definition": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          },
          "disambiguation": {
            "type": "object",
            "properties": {
              "signals": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reject_if_near": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "examples": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "ai": {
            "type": "object",
            "properties": {
              "inject_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "summary": {
                "type": "string"
              },
              "confidence": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true,
        "allOf": [
          {
            "if": {
              "required": [
                "collision_group"
              ]
            },
            "then": {
              "required": [
                "disambiguation"
              ]
            }
          }
        ]
      }
    }
  },
  "additionalProperties": true
}

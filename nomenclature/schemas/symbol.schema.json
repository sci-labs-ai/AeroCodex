{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerocodex.internal/schemas/symbol.schema.json",
  "title": "AeroCodex Symbol Registry",
  "type": "object",
  "required": [
    "version",
    "kind",
    "records"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "kind": {
      "const": "acx.symbols"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "symbol_id",
          "namespace",
          "scope",
          "surface_form",
          "display_form",
          "semantic_role",
          "definition",
          "domain",
          "status"
        ],
        "properties": {
          "symbol_id": {
            "type": "string",
            "pattern": "^acx:"
          },
          "namespace": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "surface_form": {
            "type": "string"
          },
          "display_form": {
            "type": "string"
          },
          "latex_macro": {
            "type": "string"
          },
          "semantic_role": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "frame": {
            "type": [
              "string",
              "null"
            ]
          },
          "time_scale": {
            "type": [
              "string",
              "null"
            ]
          },
          "rust": {
            "type": "object"
          },
          "status": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
